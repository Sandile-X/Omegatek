# ============================================================
# Omegatek Solutions — Admin Folder Security
# ============================================================

# --- Block directory listing ---
Options -Indexes

# --- Block all direct access to one-time utility / migration pages ---
<FilesMatch "^(admin-setup|migrate-posts)\.(html|php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# --- Block access to backup, config, and sensitive files ---
<FilesMatch "\.(bak|sql|log|env|config|conf|dist|orig|save|swp|tmp|json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# --- Tell search engines not to index any admin pages ---
<IfModule mod_headers.c>
    Header always set X-Robots-Tag "noindex, nofollow, noarchive"
</IfModule>

# --- Security headers for all admin pages ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "same-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://openrouter.ai; img-src 'self' data: blob: https:; frame-ancestors 'none';"
</IfModule>

# --- Prevent caching of sensitive admin pages ---
<FilesMatch "\.(html|php)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </IfModule>
</FilesMatch>
