# ============================================================
# Omegatek Solutions — Config Folder Protection
# Deny ALL direct HTTP access. These files are PHP-include only.
# ============================================================
<RequireAll>
    Require all denied
</RequireAll>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
