# ================================================================
# Omegatek Solutions — Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# Add .env to your .gitignore immediately.
# ================================================================

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── PayFast Payment Gateway ───────────────────────────────────
# Found in: PayFast Merchant Account → Settings → Integration
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
# Optional — set this if you configured a passphrase in PayFast
PAYFAST_PASSPHRASE=

# ── OpenRouter AI (used by admin/gemini-api.php) ──────────────
# Found in: https://openrouter.ai/account
OPENROUTER_API_KEY=
# Default model — change to any model slug on openrouter.ai
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# ── Gemini / Google AI (optional alternate AI backend) ───────
GEMINI_API_KEY=

# ── Admin PIN ─────────────────────────────────────────────────
# Fallback PIN used by gemini-api.php for admin access
# Use a strong random string (minimum 16 characters)
ADMIN_PIN=

# ── Mail / SMTP (if switching from mail() to SMTP later) ─────
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=no-reply@omegateksolutions.co.za
# MAIL_FROM_NAME=Omegatek Solutions

# ── App Environment ───────────────────────────────────────────
# Set to "production" on live server, "development" locally
APP_ENV=production
